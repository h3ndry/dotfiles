#{{{
set selection-clipboard clipboard
map <C-i> zoom in
map <C-o> zoom out
#}}}


# {{{ COLORS
set default-bg                  "#0d1117"
set default-fg                  "#7e7e7e"

set statusbar-fg                "#cccccc"
set statusbar-bg                "#0d1117"
set statusbar-basename          "true"

set inputbar-bg                 "#0d1117"
set inputbar-fg                 "#cccccc"

set notification-bg             "#0d1117"
set notification-fg             "#f9f5f7"

set notification-error-bg       "#0d1117"
set notification-error-fg       "#cc241d"

set notification-warning-bg     "#0d1117"
set notification-warning-fg     "#cc241d"

set highlight-color             "#fabd2f"
set highlight-active-color      "#458588"

set completion-bg               "#0d1117"
set completion-fg               "#458588"

set completion-highlight-fg     "#a89984"
set completion-highlight-bg     "#0d1117"

set recolor-lightcolor          "#0d1117"
set recolor-darkcolor           "#c0caf5"

set recolor                     "true"
set recolor-keephue             "true"
# }}}


# {{{ Things I copied over the internet
# Open document in fit-width mode by default
set adjust-open "best-fit"

# One page per row by default
set pages-per-row 1

#stop at page boundries
set scroll-page-aware "true"
set smooth-scroll "true"
set scroll-full-overlap 0.01
set scroll-step 240

#zoom settings
set zoom-min 10

set font "JetBrainsMono 10"
